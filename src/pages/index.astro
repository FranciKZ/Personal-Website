---
import { getCollection, render } from "astro:content";

const workEntries = (await getCollection("work")).sort(
    (a, b) => b.data.order - a.data.order,
);

const projectEntries = await getCollection("projects");

const renderedWork = await Promise.all(
    workEntries.map(async (entry) => {
        const { Content } = await render(entry);
        return { entry, Content };
    }),
);

const renderedProjects = await Promise.all(
    projectEntries.map(async (entry) => {
        const { Content } = await render(entry);
        return { entry, Content };
    }),
);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>Kollin Francis</title>
        <script
            async
            defer
            data-website-id="abc898e1-748f-4dea-bb9b-31de33399074"
            src="https://umami-production-0a42.up.railway.app/umami.js"
        ></script>
    </head>
    <body class="bg-violet text-snow">
        <nav id="site-nav">
            <a href="/" class="nav-logo">KF</a>
            <div class="nav-links">
                <a
                    href="https://github.com/FranciKZ"
                    target="_blank"
                    rel="noopener">github</a
                >
                <a
                    href="https://www.linkedin.com/in/kollin-francis/"
                    target="_blank"
                    rel="noopener">linkedin</a
                >
            </div>
        </nav>

        <section id="hero">
            <div class="hero-content">
                <h1 data-hero="0">I'm Kollin Francis.</h1>
                <div class="hero-body" data-hero="1">
                    <p>
                        Senior Full-Stack Engineer at <a
                            href="https://impact.com"
                            class="text-link">Impact.com</a
                        >.
                    </p>
                    <p>I like TypeScript and React.</p>
                    <p class="muted">I dabble in Japanese.</p>
                </div>
            </div>
        </section>

        <section id="work" class="content-section">
            <p class="section-label">work</p>
            <div class="timeline">
                {
                    renderedWork.map(({ entry, Content }, i) => (
                        <div
                            class={`tl-item animate${i === 0 ? " open" : ""}`}
                            style={`transition-delay: ${i * 80}ms`}
                            onclick="this.classList.toggle('open')"
                        >
                            <div class="tl-dot" />
                            <p class="tl-company">{entry.data.company}</p>
                            <p class="tl-role">
                                {entry.data.role} &nbsp;·&nbsp;{" "}
                                {entry.data.dates}
                            </p>
                            <div class="tl-body">
                                <div class="tl-body-inner">
                                    {entry.data.roles && (
                                        <div class="tl-roles">
                                            {entry.data.roles.join(" · ")}
                                        </div>
                                    )}
                                    <Content />
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

        <section id="projects" class="content-section">
            <p class="section-label">projects</p>
            <div class="projects-grid">
                {
                    renderedProjects.map(({ entry, Content }, i) => (
                        <div
                            class={`project-card animate${i === renderedProjects.length - 1 && renderedProjects.length % 2 !== 0 ? " full" : ""}`}
                            style={`transition-delay: ${i * 80}ms`}
                            onclick="this.classList.toggle('open')"
                        >
                            <div class="project-header">
                                <p class="project-title">{entry.data.title}</p>
                                <i
                                    class="project-chevron ti ti-chevron-down"
                                    aria-hidden="true"
                                />
                            </div>
                            <p class="project-desc">{entry.data.description}</p>
                            <div class="project-tags">
                                {entry.data.tech.map((t: string) => (
                                    <span class="tag">{t}</span>
                                ))}
                            </div>
                            <div class="project-body">
                                <div class="project-body-inner">
                                    <Content />
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>
    </body>
</html>

<style>
